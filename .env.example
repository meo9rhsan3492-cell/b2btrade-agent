# B2Btrade Agent - 环境变量配置
# 复制为 .env 后填入你的 API Key

# API Provider: openai / anthropic / google / minimax
B2B_API_PROVIDER=openai

# API Key (必需)
B2B_API_KEY=your-api-key-here

# 模型选择
# OpenAI: gpt-4o gpt-4o-mini gpt-4
# Anthropic: claude-3-5-sonnet-20241022 claude-3-5-haiku-20241022
# Google: gemini-2.0-flash gemini-1.5-pro
# MiniMax: MiniMax-M2.5
B2B_MODEL=

# 输出语言: zh / en
B2B_LOCALE=zh

# Shopify 集成 (可选)
# B2B_SHOPIFY_STORE_URL=
# B2B_SHOPIFY_ACCESS_TOKEN=

# Ali1688 集成 (可选)
# B2B_ALI1688_APP_KEY=
# B2B_ALI1688_APP_SECRET=

# TikTok Shop 集成 (可选)
# B2B_TIKTOK_CLIENT_KEY=
# B2B_TIKTOK_ACCESS_TOKEN=
