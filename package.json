{
  "name": "b2btrade-agent",
  "version": "1.1.0",
  "description": "外贸B2B智能Agent - 开箱即用的外贸AI助手",
  "main": "src/index.js",
  "type": "module",
  "bin": {
    "b2b": "./src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "chat": "node src/index.js chat",
    "search": "node src/tools/search.js",
    "config": "node src/index.js config",
    "status": "node src/index.js status",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "lint": "eslint src/ tests/",
    "pub": "npm publish --access public"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "moduleFileExtensions": [
      "js",
      "mjs"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "verbose": true
  },
  "keywords": [
    "b2b",
    "trade",
    "ai",
    "agent",
    "foreign-trade",
    "export",
    "crm",
    "linkedin",
    "whatsapp"
  ],
  "author": "EdoStra <meo9rhsan3492-cell@users.noreply.github.com>",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "dotenv": "^16.3.1",
    "inquirer": "^9.2.12",
    "readline": "^1.3.0"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
